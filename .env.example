# =============================================================================
#  FitTrack — Plantilla de variables de entorno
#  Copia este archivo a .env y completa los valores
# =============================================================================

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=cambia_esto
MYSQL_DATABASE=fitness_app
MYSQL_USER=fittrack
MYSQL_PASSWORD=cambia_esto

# ── Base de datos (backend dev: apunta a MySQL local) ─────────────────────────
# En Docker, docker-compose sobreescribe esta URL automáticamente
DATABASE_URL="mysql://fittrack:cambia_esto@localhost:3306/fitness_app"

# ── JWT (genera valores aleatorios y largos en producción) ───────────────────
JWT_SECRET=cambia_esto_por_un_secreto_largo
JWT_REFRESH_SECRET=cambia_esto_por_otro_secreto_largo
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Servidor backend ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS: URL del frontend ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ── Seed: admin inicial ───────────────────────────────────────────────────────
SEED_ADMIN_CORREO=admin@tudominio.cl
SEED_ADMIN_PASSWORD=CambiaMeAhora123!
SEED_ADMIN_NOMBRE=Administrador
SEED_ADMIN_APELLIDO=Principal
SEED_ADMIN_RUT=12345678-9
SEED_ADMIN_TELEFONO=+56912345678

# ── Docker: ejecutar seed al iniciar ─────────────────────────────────────────
# Poner true solo la primera vez (inicio limpio). Cambiar a false después.
RUN_SEED=true
